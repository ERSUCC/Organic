name = "Various usages of minus sign"
tokens = [
    '1', '-', 'test',
    '1', '+', '-', 'test',
    '1', '-', '-', 'test',
    '-', 'test', '-', '1',
    '-', 'test', '+', '1',
    '(', '-1', '-', 'test', ')',
    '(', '-1', '+', 'test', ')',
    '(', '-', 'test', '-', '1', ')',
    '(', '-', 'test', '+', '1', ')',
]

---

1 - test
1 + -test
1 - -test
-test - 1
-test + 1
(-1 - test)
(-1 + test)
(-test - 1)
(-test + 1)
