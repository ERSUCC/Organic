name = "Number variable in number input"

---

test = 440

sine(frequency: test)

---

name = "Negated number variable in number input"

---

test = -440

sine(frequency: -test)

---

name = "Constant variable in constant input"

---

test = forward

sequence(values: [ 0 ], order: test)

---

name = "Boolean variable in boolean input"

---

test = true

if(condition: test, is-true: 1, is-false: 0)

---

name = "String variable in string input"

---

test = "test"

sample(file: test)

---

name = "List variable in list input"

---

test = [ 1, 2, 3 ]

sequence(values: test)
