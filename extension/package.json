{
  "name": "organic",
  "displayName": "Organic",
  "description": "Syntax highlighting for Organic",
  "version": "0.1.0",
  "publisher": "ERSUCC",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "See LICENSE.txt",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "organic",
    "music",
    "sound",
    "audio"
  ],
  "contributes": {
    "languages": [{
      "id": "organic",
      "aliases": [
        "Organic",
        "organic"
      ],
      "extensions": [
        ".organic"
      ],
      "configuration": "./configs/organic-configuration.json",
      "icon": {
        "light": "./icons/icon-padded.png",
        "dark": "./icons/icon-padded.png"
      }
    }, {
      "id": "otest",
      "aliases": [
        "Organic Test",
        "OTest",
        "otest"
      ],
      "extensions": [
        ".otest"
      ],
      "configuration": "./configs/otest-configuration.json",
      "icon": {
        "light": "./icons/test-icon-padded.png",
        "dark": "./icons/test-icon-padded.png"
      }
    }],
    "grammars": [{
      "language": "organic",
      "scopeName": "source.organic",
      "path": "./syntaxes/organic.tmLanguage.json"
    }, {
      "language": "otest",
      "scopeName": "source.otest",
      "path": "./syntaxes/otest.tmLanguage.json",
      "embeddedLanguages": {
        "meta.embedded.section.organic": "organic"
      }
    }]
  },
  "repository": {
  	"type": "git",
  	"url": "https://github.com/ERSUCC/Organic"
  },
  "icon": "./icons/icon-full.png"
}
